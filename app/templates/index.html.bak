{% extends "base.html" %}
{% block content %}

<!-- ═══ HERO ═══════════════════════════════════════════ -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-label">Екатеринбург — официальный дилер</p>
        <h1 class="hero-title">
          Системы<br>
          <span>видеонаблюдения</span><br>
          под ключ
        </h1>
        <p class="hero-desc">
          Продажа, проектирование и профессиональная установка. 
          Мультибрендовый ассортимент: Hikvision, Matrix, Trassir и другие. 
          Гарантия на оборудование и монтаж.
        </p>
        <div class="hero-btns">
          <a href="/catalog" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="6" height="6"/><rect x="9" y="3" width="6" height="6"/><rect x="16" y="3" width="6" height="6"/><rect x="2" y="10" width="6" height="6"/><rect x="9" y="10" width="6" height="6"/><rect x="16" y="10" width="6" height="6"/></svg>
            Каталог товаров
          </a>
          <a href="/services" class="btn-outline">Наши услуги</a>
        </div>
        <div class="hero-stats">
          <div>
            <div class="hero-stat-val">500+</div>
            <div class="hero-stat-lbl">объектов под охраной</div>
          </div>
          <div>
            <div class="hero-stat-val">10 лет</div>
            <div class="hero-stat-lbl">на рынке Екатеринбурга</div>
          </div>
          <div>
            <div class="hero-stat-val">24/7</div>
            <div class="hero-stat-lbl">техподдержка</div>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-steps">
          <div class="hero-step">
            <div class="hero-step-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <div>
              <div class="hero-step-title">Консультация и выезд</div>
              <div class="hero-step-sub">от 500 рулей в день обращения.</div>
            </div>
          </div>
          <div class="hero-step">
            <div class="hero-step-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
            </div>
            <div>
              <div class="hero-step-title">Проект и смета</div>
              <div class="hero-step-sub">Подбор оборудования под объект</div>
            </div>
          </div>
          <div class="hero-step">
            <div class="hero-step-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <div>
              <div class="hero-step-title">Монтаж за 1–3 дня</div>
              <div class="hero-step-sub">Профессиональная установка</div>
            </div>
          </div>
          <div class="hero-step hero-step-last">
            <div class="hero-step-icon hero-step-icon-green">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <div class="hero-step-title">Гарантия 2 года</div>
              <div class="hero-step-sub">На оборудование и монтаж</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CATEGORIES ════════════════════════════════════ -->
{% if categories %}
<section class="section-sm">
  <div class="container">
    <div class="categories-strip">
      {% for cat in categories %}
      <a href="/catalog/category/{{ cat.slug }}" class="cat-chip">
        {{ cat.name }}
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ═══ FEATURED PRODUCTS ════════════════════════════ -->
{% if featured %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Популярные <span>товары</span></h2>
      <a href="/catalog" class="section-link">Весь каталог →</a>
    </div>
    <div class="products-grid">
      {% for p in featured %}
      <div class="product-card">
        <div class="product-img-wrap">
          {% if p.images %}
            <img src="{{ p.images[0] }}" alt="{{ p.name }}" loading="lazy">
          {% else %}
            <div class="product-no-img">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            </div>
          {% endif %}
          {% if p.old_price > p.price and p.old_price > 0 %}
            <span class="product-badge sale">Скидка</span>
          {% endif %}
        </div>
        <div class="product-body">
          {% if p.brand %}<div class="product-brand">{{ p.brand }}</div>{% endif %}
          <div class="product-name"><a href="/catalog/{{ p.slug }}">{{ p.name }}</a></div>
          {% if p.sku %}<div class="product-sku">Арт.: {{ p.sku }}</div>{% endif %}
          <div class="product-price-row">
            <div>
              <div class="product-price">{{ ("{:,.0f}".format(p.price)).replace(",", " ") }} ₽</div>
              {% if p.old_price > p.price and p.old_price > 0 %}
                <div class="product-old-price">{{ ("{:,.0f}".format(p.old_price)).replace(",", " ") }} ₽</div>
              {% endif %}
            </div>
            <button class="product-add-btn" 
              @click="cart.add({ id: {{ p.id }}, name: '{{ p.name | replace("'", "\\'") }}', sku: '{{ p.sku }}', price: {{ p.price }} })"
              title="В корзину">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </button>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ═══ WHY US ════════════════════════════════════════ -->
<section class="section" style="background: linear-gradient(180deg, transparent, rgba(0,229,255,0.02), transparent)">
  <div class="container">
    <div class="section-header" style="justify-content: center; text-align:center; display:block; margin-bottom:50px">
      <h2 class="section-title" style="display:inline-block">Почему выбирают <span>нас</span></h2>
      <p style="color:var(--text-muted); margin-top:12px">Официальный дилер ведущих производителей в Екатеринбурге</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Официальный дилер</h3>
        <p>Прямые поставки от производителей. Оригинальное оборудование с гарантией.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3>Быстрый монтаж</h3>
        <p>Выезд на объект в день обращения. Монтаж под ключ за 1–3 дня.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/></svg>
        </div>
        <h3>Гарантия 2 года</h3>
        <p>Гарантия на всё оборудование и выполненные монтажные работы.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.6 4.4 2 2 0 0 1 3.57 2.19h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17z"/></svg>
        </div>
        <h3>Поддержка 24/7</h3>
        <p>Телефонная и выездная техподдержка в любое время суток.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ SERVICES ══════════════════════════════════════ -->
{% if services %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Наши <span>услуги</span></h2>
      <a href="/services" class="section-link">Все услуги →</a>
    </div>
    <div class="services-grid">
      {% for svc in services %}
      <a href="/services/{{ svc.slug }}" class="service-card">
        <div class="service-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="service-name">{{ svc.name }}</h3>
        <p class="service-desc">{{ svc.short_description }}</p>
        {% if svc.price_from %}
          <p class="service-price">от {{ ("{:,.0f}".format(svc.price_from)).replace(",", " ") }} ₽</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ═══ CTA ═══════════════════════════════════════════ -->
<div class="container">
  <div class="cta-strip">
    <h2>Нужна <span style="color:var(--accent)">консультация?</span></h2>
    <p>Подберём оптимальное решение для вашего объекта. Выезд и расчет стоимости от 500 рублей..</p>
    <a href="tel:{{ site_phone|replace(' ','') }}" class="btn-primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.6 4.4 2 2 0 0 1 3.57 2.19h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17z"/></svg>
      {{ site_phone }}
    </a>
  </div>
</div>

<!-- ═══ BLOG ══════════════════════════════════════════ -->
{% if posts %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Из <span>блога</span></h2>
      <a href="/blog" class="section-link">Все статьи →</a>
    </div>
    <div class="blog-grid">
      {% for post in posts %}
      <div class="blog-card">
        <div class="blog-cover">
          {% if post.cover_image %}
            <img src="{{ post.cover_image }}" alt="{{ post.title }}" loading="lazy">
          {% else %}
            <div style="height:180px; display:flex; align-items:center; justify-content:center; color:var(--text-muted)">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
            </div>
          {% endif %}
        </div>
        <div class="blog-body">
          <div class="blog-date">{{ post.created_at.strftime('%d.%m.%Y') }}</div>
          <h3 class="blog-title"><a href="/blog/{{ post.slug }}">{{ post.title }}</a></h3>
          <p class="blog-excerpt">{{ post.excerpt[:120] }}{% if post.excerpt|length > 120 %}...{% endif %}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<style>
.categories-strip { display: flex; flex-wrap: wrap; gap: 10px; }
.cat-chip {
  padding: 8px 18px; border-radius: 30px;
  border: 1px solid var(--border); color: var(--text-dim);
  font-size: 14px; transition: all 0.2s;
}
.cat-chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

.why-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 24px;
}
.why-card {
  padding: 28px; background: var(--bg-card);
  border: 1px solid var(--border); border-radius: var(--radius);
  transition: all 0.25s;
}
.why-card:hover { border-color: var(--border-hover); transform: translateY(-3px); }
.why-icon {
  width: 52px; height: 52px; background: var(--accent-dim);
  border-radius: 12px; display: flex; align-items: center; justify-content: center;
  color: var(--accent); margin-bottom: 16px;
}
.why-card h3 { font-size: 20px; margin-bottom: 10px; }
.why-card p { font-size: 14px; color: var(--text-dim); }
</style>
{% endblock %}
